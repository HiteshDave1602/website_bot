      "parameters": {
        "jsCode": "let inputUrl =\n  $json.body?.url ??\n  $json.body?.source_url ??\n  $json.query?.url ??\n  $json.query?.source_url ??\n  $json.url ??\n  $json.source_url;\n\nif (inputUrl === undefined || inputUrl === null) {\n  throw new Error('URL is missing. Send \"url\" or \"source_url\".');\n}\n\ninputUrl = String(inputUrl)\n  .trim()\n  .replace(/^[\"']+|[\"']+$/g, '')\n  .replace(/\\r/g, '')\n  .replace(/\\n/g, '')\n  .replace(/\\t/g, '')\n  .replace(/ /g, '');\n\n// Handle protocol-relative URLs such as //www.vrattiks.io/\nif (inputUrl.startsWith('//')) {\n  inputUrl = `https:${inputUrl}`;\n}\n\n// Handle URLs without a protocol\nif (!/^https?:\\/\\//i.test(inputUrl)) {\n  inputUrl = `https://${inputUrl}`;\n}\n\n// Normalize malformed protocol slashes\ninputUrl = inputUrl\n  .replace(/^https?:\\/\\/\\/+/i, 'https://')\n  .replace(/^https:\\/(?!\\/)/i, 'https://')\n  .replace(/^http:\\/(?!\\/)/i, 'http://');\n\n// Validate and extract hostname without using new URL()\nconst urlMatch = inputUrl.match(\n  /^(https?):\\/\\/([^/?#]+)(\\/[^?#]*)?(\\?[^#]*)?(#.*)?$/i\n);\n\nif (!urlMatch) {\n  throw new Error(`Invalid URL format after cleaning: \"${inputUrl}\"`);\n}\n\nconst protocol = urlMatch[1].toLowerCase();\nconst hostWithPort = urlMatch[2];\nconst pathname = urlMatch[3] || '';\n\n// Remove username/password if accidentally provided\nconst hostPart = hostWithPort.split('@').pop();\n\n// Remove port when creating website_id\nconst hostname = hostPart.split(':')[0].toLowerCase();\n\nif (\n  !hostname ||\n  hostname.includes(' ') ||\n  !hostname.includes('.')\n) {\n  throw new Error(`Invalid hostname: \"${hostname}\"`);\n}\n\nconst source_url = `${protocol}://${hostWithPort}${pathname}`\n  .replace(/\\/+$/, '');\n\nconst website_id = hostname\n  .replace(/^www\\./i, '')\n  .replace(/[^a-z0-9]+/gi, '-')\n  .replace(/^-+|-+$/g, '')\n  .toLowerCase();\n\nreturn [\n  {\n    json: {\n      success: true,\n      source_url,\n      website_id,\n      cleaned_input: inputUrl,\n    },\n  },\n];"
      },

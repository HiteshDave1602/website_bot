      "parameters": {
        "jsCode": "const website_id = $json.website_id || $('Normalize Request1').first().json.website_id;\nconst pages = Array.isArray($json.pages) ? $json.pages : [];\nconst successful = pages.filter(page => page && typeof page.markdown === 'string' && page.markdown.trim().length >= 50);\nconst text_length = successful.reduce((sum, page) => sum + page.markdown.trim().length, 0);\n\nif (successful.length === 0 || text_length < 50) {\n  return [{\n    json: {\n      success: false,\n      website_id,\n      pages_checked: pages.length,\n      successful_pages: 0,\n      text_length,\n      error: 'The crawl-api did not return enough readable markdown for this website. Check the Crawl Pages node output for failed or empty_content pages.'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    success: true,\n    website_id,\n    pages_checked: pages.length,\n    pages_indexed: successful.length,\n    text_length,\n    chatbot_url: `https://website-bot-frontend-1klt.onrender.com/${website_id}/chat`\n  }\n}];"
      },

      "parameters": {
        "jsCode": "const normalized = $('Normalize Request1').first().json;\nconst chunks = $('Chunk Text3').all();\n\nreturn $input.all().map((item, index) => {\n  const values = item.json.embedding?.values || item.json.embeddings?.[0]?.values;\n  const original = chunks[index]?.json;\n\n  if (!Array.isArray(values) || values.length === 0) {\n    throw new Error(`Embedding values are missing for chunk ${index}`);\n  }\n\n  if (!original?.text) {\n    throw new Error(`Original chunk text is missing for chunk ${index}`);\n  }\n\n  return {\n    json: {\n      content: original.text,\n      website_id: normalized.website_id,\n      source_url: original.metadata?.url || normalized.source_url,\n      metadata: {\n        ...(original.metadata || {}),\n        website_id: normalized.website_id,\n        source_url: normalized.source_url,\n        chunk_index: index,\n      },\n      embedding: `[${values.join(',')}]`,\n    },\n  };\n});"
      },
